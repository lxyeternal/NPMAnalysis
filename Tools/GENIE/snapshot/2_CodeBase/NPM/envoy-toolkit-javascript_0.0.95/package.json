{
  "name": "envoy-toolkit-javascript",
  "version": "0.0.95",
  "description": "Envoy toolkit for vanilla javascript",
  "scripts": {
    "build": "microbundle -f umd --sourcemap=false",
    "dev": "microbundle --no-compress -f umd watch",
    "cleanbuild": "rm -rf ./dist && npm run build",
    "publish-version": "yarn publish --patch --tag latest",
    "bump:patch": "yarn version --new-version patch --no-git-tag-version"
  },
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.module.js",
  "unpkg": "./dist/index.umd.js",
  "types": "./dist/index.d.ts",
  "author": "Envoy-Technology",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.7",
    "envoy-toolkit-core": "latest",
    "microbundle": "^0.15.0",
    "postcss": "^8.4.14",
    "tailwindcss": "^3.0.24",
    "typescript": "^4.7.2"
  },
  "dependencies": {}
}
